            "faq": {
              "title": "Frequently Asked Questions",
              "description": "Grand Tale is a high-fantasy social life-sim game which hosts sub-games of multiple genres. The game is set in a world where players can explore, create, and explore their own worlds. The game is a living, breathing world that respects your time and intelligence.",
              "groups": {
                "general": {
                  "title": "General",
                  "q1": {
                    "question": "What is Grand Tale?",
                    "answer": "Grand Tale is a high-fantasy social life-sim game which hosts sub-games of multiple genres. The game is set in a world where players can explore, create, and explore their own worlds. The game is a living, breathing world that respects your time and intelligence."
                  },
                  "q2": {
                    "question": "When will Grand Tale be released?",
                    "answer": "Grand Tale is currently in active development. Stay tuned to our news section for release date announcements."
                  },
                  "q3": {
                    "question": "On which platforms will Grand Tale be available?",
                    "answer": "We are targeting a multi-platform release including PC and major consoles."
                  }
                },
                "gameplay": {
                  "title": "Gameplay",
                  "q1": {
                    "question": "What can I do in Grand Tale?",
                    "answer": "You can explore a vast open world, engage in various sub-games across different genres, build your own home, and socialize with players worldwide."
                  },
                  "q2": {
                    "question": "Is there a multiplayer mode?",
                    "answer": "Yes! Grand Tale is a social experience at its core, featuring persistent multiplayer environments and collaborative activities."
                  },
                  "q3": {
                    "question": "Can I customize my character?",
                    "answer": "Extensively. Our deep character creator allows you to define your look, while our progression system lets you define your playstyle."
                  }
                },
                "technical": {
                  "title": "Technical",
                  "q1": {
                    "question": "What are the system requirements?",
                    "answer": "System requirements will be finalized closer to release. We aim to support a wide range of hardware."
                  },
                  "q2": {
                    "question": "Does Grand Tale support controllers?",
                    "answer": "Yes, Grand Tale will feature full controller support on all platforms."
                  },
                  "q3": {
                    "question": "How do I report a bug?",
                    "answer": "During our testing phases, you can report bugs through our official discord or the support section of our website."
                  }
                }
              },
              "footer": "Have a question that isn't covered in this FAQ? Check out our {link}."
            }
          }
        },
