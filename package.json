{
  "name": "rimelight-com",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync": "rimelight sync && husky && nuxt prepare",
    "sync:agents": "rimelight sync --agents",
    "sync:configs": "rimelight sync --configs",
    "analyze": "nuxi analyze",
    "version:sync": "bun run scripts/bump-version.ts",
    "build": "bun run version:sync && nuxt build",
    "build:web": "bun run build",
    "build:android": "bun run version:sync && bun run generate && bun tauri android build --target aarch64 armv7",
    "build:tauri": "NUXT_PUBLIC_API_BASE=https://rimelight.com NUXT_APP_TARGET=tauri bun run generate",
    "dev": "nuxt dev",
    "dev:tauri": "tauri dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "i18n": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\"",
    "i18n:add": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --add",
    "i18n:remove": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --remove",
    "i18n:fix": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --add --remove",
    "typecheck": "nuxt prepare && vue-tsc --noEmit && nuxt typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "check": "bun run i18n && bun run typecheck && bun run lint && bun run format",
    "fix": "bun run i18n:fix && bun run lint:fix && bun run format:fix",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "tauri": "tauri",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "vitest --project e2e"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.5.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@unhead/vue": "^2.1.2",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "better-sqlite3": "^12.6.2",
    "cobe": "^0.6.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "nuxt": "^4.3.1",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3",
    "y-protocols": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@nuxt/a11y": "^1.0.0-alpha.1",
    "@nuxt/devtools": "^3.2.2",
    "@nuxt/hints": "^1.0.0-alpha.10",
    "@nuxt/schema": "^4.3.1",
    "@nuxt/test-utils": "^3.23.0",
    "@tauri-apps/cli": "^2.10.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "drizzle-kit": "^0.31.9",
    "husky": "^9.1.7",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "rimelight-cli": "github:Rimelight-Entertainment/rimelight-cli",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-i18n-extract": "^2.0.7",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.68.1"
  }
}
