    "@tauri-apps/cli": "^2.9.6",
    "drizzle-kit": "^0.31.8",
    "oxfmt": "^0.17.0",
    "oxlint": "^1.42.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16",
    "vue-tsc": "^3.1.8",
    "wrangler": "^4.61.1"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@tailwindcss/oxide",
    "esbuild",
    "sharp",
    "vue-demi",
    "workerd"
