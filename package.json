{
  "name": "rimelight.com",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "analyze": "nuxi analyze",
    "build": "pnpm version:sync && nuxt build",
    "build:web": "pnpm build",
    "build:android": "pnpm version:sync && pnpm generate && pnpm tauri android build --target aarch64 armv7",
    "build:tauri": "NUXT_PUBLIC_API_BASE=https://rimelight.com NUXT_APP_TARGET=tauri pnpm generate",
    "dev": "nuxt dev",
    "dev:tauri": "tauri dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "i18n": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\"",
    "i18n:add": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --add",
    "i18n:remove": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --remove",
    "i18n:fix": "vue-i18n-extract report --vueFiles \"./{app,server,shared,auth,types}/**/*.?(js|vue|ts)\" --languageFiles \"./i18n/locales/*.?(json|yml|yaml|js)\" --add --remove",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "tauri": "tauri"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^0.13.2",
    "@nuxt/ui": "^4.5.1",
    "@nuxtjs/i18n": "^10.2.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@unhead/vue": "^2.1.12",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "better-sqlite3": "^12.8.0",
    "cobe": "^0.6.5",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "nuxt": "^4.4.2",
    "tsx": "^4.21.0",
    "vite-plus": "^0.1.12",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "y-protocols": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/devtools": "^3.2.3",
    "@nuxt/hints": "^1.0.0",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "drizzle-kit": "^0.31.9",
    "rimelight-cli": "github:Rimelight-Entertainment/rimelight-cli",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vue-i18n-extract": "^2.0.7",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.74.0"
  },
  "packageManager": "pnpm@10.32.1"
}
