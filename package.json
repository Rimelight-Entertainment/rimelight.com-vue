{
  "name": "rimelight-com",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.5",
  "scripts": {
    "analyze": "nuxi analyze",
    "build": "nuxi build",
    "build:web": "bun run build",
    "build:tauri": "NUXT_PUBLIC_API_BASE=https://rimelight.com NUXT_APP_TARGET=tauri bun run generate",
    "dev": "nuxt dev",
    "dev:tauri": "tauri dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "vue-tsc --noEmit && nuxt typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "check": "bun run typecheck && bun run lint && bun run format",
    "fix": "bun run lint:fix && bun run format:fix",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "tauri": "tauri"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.2.1",
    "@nuxtjs/device": "^3.2.4",
    "@nuxtjs/i18n": "^10.2.1",
    "@nuxtjs/robots": "5.5.6",
    "@nuxtjs/sitemap": "^7.5.0",
    "@pinia/colada": "^0.20.0",
    "@pinia/colada-nuxt": "0.3.0",
    "@pinia/nuxt": "0.11.3",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-autostart": "~2",
    "@tauri-apps/plugin-http": "^2.5.4",
    "@tauri-apps/plugin-process": "~2",
    "@unhead/vue": "^2.0.19",
    "@vueuse/core": "^14.1.0",
    "@vueuse/nuxt": "^14.1.0",
    "better-auth": "^1.4.7",
    "cobe": "^0.6.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "drizzle": "^1.4.0",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "motion-v": "^1.7.4",
    "nuxt": "npm:nuxt-nightly@latest",
    "nuxt-og-image": "^5.1.13",
    "pinia": "^3.0.4",
    "rimelight-components": "^2.1.37",
    "uuid": "^13.0.0",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0",
    "zod": "^4.2.1"
  },
  "overrides": {
